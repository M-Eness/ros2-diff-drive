<?xml version="1.0"?>
<robot name="bumperbot">

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="silver">
    <color rgba="0.79 0.82 0.93 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <link name="base_footprint"/>

<link name="base_link">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <mass value="0.8257"/>
      <inertia ixx="0.0221" ixy="-0.0001" ixz="0.0003"
               iyy="0.0211" iyz="-0.00005"
               izz="0.0200" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.3 0.15"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <geometry>
        <box size="0.3 0.3 0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <origin xyz="0 0 0.033" rpy="0 0 0"/>
  </joint>

  <link name="wheel_right_link">
    <inertial>
      <origin xyz="0 -0.014 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.0000188" ixy="0" ixz="0"
               iyy="0.0000311" iyz="0"
               izz="0.0000188" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <origin xyz="0 -0.12 0" rpy="0 0 0" /> <parent link="base_link" />
    <child link="wheel_right_link" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="wheel_left_link">
    <inertial>
      <origin xyz="0 0.014 0" rpy="0 0 0" />
      <mass value="0.2" />
      <inertia ixx="0.0000188" ixy="0" ixz="0"
               iyy="0.0000311" iyz="0"
               izz="0.0000188" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry>
        <cylinder radius="0.033" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <origin xyz="0 0.12 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="wheel_left_link" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="caster_front_link">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="caster_front_joint" type="continuous">
    <origin xyz="0.12 0 -0.018" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_front_link" />
  </joint>

  <link name="caster_rear_link">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="caster_rear_joint" type="continuous">
    <origin xyz="-0.12 0 -0.018" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="caster_rear_link" />
  </joint>

  <link name="laser_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.07"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0 0 0.12" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser_link" />
  </joint>


  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

    <joint name="camera_joint" type="fixed">
    <!-- Kamerayı robotun önüne ve biraz yukarı koyuyoruz -->
    <origin xyz="0.10 0.06 0.18" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>


  <gazebo reference="wheel_right_link">
    <mu1>1.0</mu1> <mu2>1.0</mu2>
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="wheel_left_link">
    <mu1>1.0</mu1> <mu2>1.0</mu2>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="caster_front_link">
    <mu1>0.0</mu1> <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="caster_rear_link">
    <mu1>0.0</mu1> <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

<gazebo reference="laser_link">
    <sensor name='lidar' type='gpu_lidar'>
      <pose>0 0 0 0 0 0</pose>
      <topic>/scan</topic> <frame_id>laser_link</frame_id>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples><resolution>1</resolution>
            <min_angle>-3.14</min_angle><max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min><max>30.0</max><resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
</gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>50.0</far>
        </clip>
      </camera>

      <always_on>true</always_on>
      <visualize>true</visualize>

      <!-- ROS2 -->
      <topic>/camera/image_raw</topic>
      <frame_id>camera_link</frame_id>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="libignition-gazebo-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_publish_frequency>30</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <!-- Ignition'da topic ismi model prefixi ile gelir -->
      <tf_topic>/model/my_robot/tf</tf_topic>
      <odom_topic>/model/my_robot/odometry</odom_topic>
      <publish_tf>true</publish_tf>
    </plugin>
    <plugin filename="libignition-gazebo-sensors-system.so" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

</robot>