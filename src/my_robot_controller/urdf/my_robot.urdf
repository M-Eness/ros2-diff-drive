<?xml version="1.0"?>
<robot name="bumperbot">

  <material name="blue"><color rgba="0 0 1 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>
  <material name="silver"><color rgba="0.79 0.82 0.93 1"/></material>
  <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.2" rpy="0 0 0" />
      <mass value="500.0"/>
      <inertia ixx="60.0" ixy="0" ixz="0" iyy="120.0" iyz="0" izz="150.0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0" />
      <geometry><box size="2.0 1.2 0.4"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0" />
      <geometry><box size="2.0 1.2 0.4"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <origin xyz="0 0 0.165" rpy="0 0 0"/>
  </joint>

  <!-- REAR RIGHT WHEEL -->
  <link name="rear_right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="5.0" />
      <!-- izz: içi dolu silindir formülü 0.5*m*r^2 = 0.5*5*0.165^2 ≈ 0.068 -->
      <inertia ixx="0.068" ixy="0" ixz="0" iyy="0.068" iyz="0" izz="0.068" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
    </collision>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <origin xyz="-0.6 -0.65 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rear_right_wheel_link" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- REAR LEFT WHEEL -->
  <link name="rear_left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="5.0" />
      <inertia ixx="0.068" ixy="0" ixz="0" iyy="0.068" iyz="0" izz="0.068" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
    </collision>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <origin xyz="-0.6 0.65 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rear_left_wheel_link" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- FRONT RIGHT STEERING -->
  <link name="front_right_steering_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="front_right_steering_joint" type="revolute">
    <origin xyz="0.6 -0.65 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_right_steering_link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>

  <!-- FRONT RIGHT WHEEL -->
  <link name="front_right_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="5.0" />
      <inertia ixx="0.068" ixy="0" ixz="0" iyy="0.068" iyz="0" izz="0.068" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
    </collision>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="front_right_steering_link" />
    <child link="front_right_wheel_link" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- FRONT LEFT STEERING -->
  <link name="front_left_steering_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="front_left_steering_joint" type="revolute">
    <origin xyz="0.6 0.65 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_left_steering_link" />
    <axis xyz="0 0 1" />
    <limit lower="-0.6" upper="0.6" effort="100" velocity="10"/>
  </joint>

  <!-- FRONT LEFT WHEEL -->
  <link name="front_left_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="5.0" />
      <inertia ixx="0.068" ixy="0" ixz="0" iyy="0.068" iyz="0" izz="0.068" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry><cylinder radius="0.165" length="0.1"/></geometry>
    </collision>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="front_left_steering_link" />
    <child link="front_left_wheel_link" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- LASER -->
  <link name="laser_link">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0 0 0.6" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser_link" />
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.95 0 1.2" rpy="0 0.35 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <!-- camera_gta_link: /camera/gta_view'a yayın yapıyor, algı pipeline'ı
       (/camera/image_raw) etkilemiyor. İhtiyaç yoksa kaldırılabilir. -->
  <link name="camera_gta_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_gta_joint" type="fixed">
    <origin xyz="0 0 15.0" rpy="0 1.5707 0"/>
    <parent link="base_link"/>
    <child link="camera_gta_link"/>
  </joint>

  <!-- GAZEBO WHEEL PROPERTIES (ZIPLAMAYI ÖNLEMEK İÇİN YUMUŞATILDI) -->
  <gazebo reference="rear_right_wheel_link">
    <mu1>1.5</mu1> <mu2>1.5</mu2>
    <kp>5000.0</kp> <kd>80.0</kd>
    <minDepth>0.01</minDepth>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="rear_left_wheel_link">
    <mu1>1.5</mu1> <mu2>1.5</mu2>
    <kp>5000.0</kp> <kd>80.0</kd>
    <minDepth>0.01</minDepth>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="front_right_wheel_link">
    <mu1>1.0</mu1> <mu2>1.0</mu2>
    <kp>5000.0</kp> <kd>80.0</kd>
    <minDepth>0.01</minDepth>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="front_left_wheel_link">
    <mu1>1.0</mu1> <mu2>1.0</mu2>
    <kp>5000.0</kp> <kd>80.0</kd>
    <minDepth>0.01</minDepth>
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- GAZEBO SENSORS -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>/imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="camera_gta_link">
    <sensor name="gta_camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.1</near><far>200.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>/camera/gta_view</topic>
      <frame_id>camera_gta_link</frame_id>
    </sensor>
  </gazebo>

  <gazebo reference="laser_link">
    <sensor name='lidar' type='gpu_lidar'>
      <pose>0 0 0 0 0 0</pose>
      <topic>/scan</topic>
      <frame_id>laser_link</frame_id>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples><resolution>1</resolution>
            <min_angle>-3.14</min_angle><max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.20</min><max>30.0</max><resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.5707</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.1</near><far>50.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>/camera/image_raw</topic>
      <frame_id>camera_link</frame_id>
    </sensor>
  </gazebo>

  <!-- cmd_vel topic uyumu: bu plugin /model/bumperbot/cmd_vel dinliyor,
       bridge_params.yaml'da ROS_TO_GZ yönünde /cmd_vel -> bu topic'e
       mapping VAR (config/bridge_params.yaml, doğrulandı). -->
  <gazebo>
    <plugin filename="libignition-gazebo-ackermann-steering-system.so"
            name="ignition::gazebo::systems::AckermannSteering">
      <left_steering_joint>front_left_steering_joint</left_steering_joint>
      <right_steering_joint>front_right_steering_joint</right_steering_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_base>1.2</wheel_base>
      <wheel_separation>1.3</wheel_separation>
      <wheel_radius>0.165</wheel_radius>
      <min_steer>-0.6</min_steer>
      <max_steer>0.6</max_steer>
      <odom_publish_frequency>30</odom_publish_frequency>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <topic>/model/bumperbot/cmd_vel</topic>
    </plugin>

    <plugin filename="libignition-gazebo-sensors-system.so"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <plugin filename="libignition-gazebo-imu-system.so"
            name="ignition::gazebo::systems::Imu">
    </plugin>

    <plugin filename="libignition-gazebo-joint-state-publisher-system.so"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- NOT: <max_step_size>0.001</max_step_size> burada EKLENMEDİ.
       Bu, fizik motoru adım büyüklüğü ayarıdır ve robot URDF'sindeki
       <gazebo> bloğuna değil, dünya (.world) dosyasındaki <physics>
       elementine ait olmalıdır:

         <world name="robotaksi_world">
           <physics name="default_physics" type="ode">
             <max_step_size>0.001</max_step_size>
             <real_time_factor>1.0</real_time_factor>
           </physics>
           ...
         </world>

       Bunu robot URDF'sine eklemek hiçbir etki yaratmaz çünkü bu plugin
       bloğu fizik motorunu değil, robotun sensör/aktüatör sistemlerini
       tanımlıyor. Eğer lidar jitter / kararsızlık sorunu varsa, ilgili
       worlds/robotaksi.world dosyasını paylaş, orada düzeltelim. -->

</robot>